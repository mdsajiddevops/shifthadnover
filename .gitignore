# Virtual environment
venv/
env/
.venv/
.env/

# Python cache files
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Environment variables — only .example templates are committed
.env
.env.*
!.env.example
!.env.domain.example
!.env.http-only.example

# Database
*.db
*.sqlite3

# Logs
*.log
logs/

# OS files
.DS_Store
Thumbs.db

# Flask instance folder

# Coverage reports
htmlcov/
.coverage
.coverage.*
coverage.xml

# pytest
.pytest_cache/

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Backup files
*.backup
*.bak

# Binary documentation — maintained in Confluence, not git
*.pdf
*.docx
*.doc
*.xls
*.xlsx
*.ppt
*.pptx

# TLS certificates and private keys — managed via Docker secrets
private.key
fullchain.pem
*.pfx
*.pem
*.key
*.crt
*.cer

# Database dumps — never commit these
*.sql
!migrations/*.sql
!migration/*.sql
!schema/*.sql
!scripts/migrations/*.sql

local_shifthandover.db

# Docker secrets source files — managed outside version control
secrets/*
!secrets/README.md

# Dev/design artifacts — not part of production source
archive/
mockups/
_dev_cleanup/

# Playwright MCP
.playwright-mcp/
