{% extends "base.html" %}

{% block content %}
<link rel="stylesheet" href="/static/dashboard_enhanced.css">
<link rel="stylesheet" href="/static/dashboard_modern.css">

<div class="dashboard-container">
    <div class="dashboard-header">
        <div class="d-flex justify-content-between align-items-center">
            <h2 class="mb-0">Operations Dashboard</h2>
            <div class="d-flex align-items-center">
                <span id="current-time"></span>
            </div>
        </div>
    </div>

    <!-- Incident Assignment Notifications Panel -->
    <div id="incident-notifications-dashboard" class="alert alert-warning" style="display: block;">
        <div class="d-flex align-items-center justify-content-between">
            <div class="flex-grow-1">
                <h5 class="alert-heading mb-2">
                    <i class="fas fa-bell text-warning me-2"></i>
                    You have <span id="notifications-count">1</span> pending incident assignment(s)
                </h5>
                <div id="notifications-summary" class="mb-0">
                    TEST: 1 pending assignment - DAVID-NOTIFICATION-TEST
                </div>
            </div>
            <div class="ms-3">
                <button type="button" class="btn btn-outline-warning btn-sm" onclick="viewAllNotifications()">
                    <i class="fas fa-eye me-1"></i>View All
                </button>
                <button type="button" class="btn btn-outline-secondary btn-sm ms-2" onclick="toggleNotificationsList()">
                    <i class="fas fa-chevron-down" id="toggle-notifications-icon"></i>
                </button>
            </div>
        </div>
        
        <!-- Detailed notifications list -->
        <div id="notifications-list-dashboard" class="mt-3" style="display: block;">
            TEST INCIDENT: DAVID-NOTIFICATION-TEST<br>This is a test notification for debugging purposes<br><small>Assigned by: test_user - 2025-10-31 12:00:00</small>
        </div>
    </div>

    <!-- Modern Glass-Morphism Statistics Cards -->
    <div class="row g-4 mb-4">
        <div class="col-lg-3 col-md-6">
            <div class="modern-stats-card success">
                <div class="stats-content">
                    <div class="stats-icon">🚨</div>
                    <div class="stats-details">
                        <div class="stats-number counter" data-target="{{ open_incidents|length }}">{{ open_incidents|length }}</div>
                        <div class="stats-label">Recent Handovers</div>
                    </div>
                    {% if open_incidents|length > 0 %}
                    <div class="notification-badge">!</div>
                    {% endif %}
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="modern-stats-card warning">
                <div class="stats-content">
                    <div class="stats-icon">⚠️</div>
                    <div class="stats-details">
                        <div class="stats-number counter" data-target="{{ priority_incidents|length }}">{{ priority_incidents|length }}</div>
                        <div class="stats-label">Priority Incidents</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="modern-stats-card info">
                <div class="stats-content">
                    <div class="stats-icon">⏰</div>
                    <div class="stats-details">
                        <div class="stats-number" id="shift-countdown">{{ current_shift_type }}</div>
                        <div class="stats-label">Current Shift</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="modern-stats-card accent">
                <div class="stats-content">
                    <div class="stats-icon">👥</div>
                    <div class="stats-details">
                        <div class="stats-number counter" data-target="{{ current_engineers|length }}">{{ current_engineers|length }}</div>
                        <div class="stats-label">On Duty Now</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Enhanced Content Cards -->
    <div class="row g-4">
        <div class="col-lg-6">
            <div class="modern-content-card">
                <h5 class="d-flex align-items-center mb-3">
                    <i class="bi bi-exclamation-triangle-fill text-warning me-2"></i>
                    Recent Handover Incidents
                    <span class="badge ms-2">{{ open_incidents|length }}</span>
                </h5>
                {% if open_incidents %}
                    <div class="incidents-list">
                        {% for incident in open_incidents[:5] %}
                        <div class="modern-incident-item">
                            <div class="d-flex justify-content-between align-items-start">
                                <div class="flex-grow-1">
                                    <div class="incident-title">{{ incident.title }}</div>
                                    <div class="incident-meta">
                                        <span class="badge bg-{{ 'danger' if incident.priority == 'High' or incident.priority == 'Critical' else 'warning' if incident.priority == 'Medium' else 'info' }} me-2">
                                            {{ incident.priority }}
                                        </span>
                                        <span class="badge bg-secondary me-2">{{ incident.type }}</span>
                                        <span class="text-muted small">{{ incident.status }}</span>
                                    </div>
                                    {% if incident.description %}
                                    <div class="incident-desc">{{ incident.description[:100] }}{% if incident.description|length > 100 %}...{% endif %}</div>
                                    {% endif %}
                                    {% if incident.assigned_to %}
                                    <div class="incident-assigned">
                                        <i class="bi bi-person-fill text-info me-1"></i>
                                        {{ incident.assigned_to }}
                                    </div>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                        {% endfor %}
                        {% if open_incidents|length > 5 %}
                        <div class="text-center mt-2">
                            <small class="text-muted">{{ open_incidents|length - 5 }} more incidents...</small>
                        </div>
                        {% endif %}
                    </div>
                {% else %}
                    <div class="text-center py-3">
                        <i class="bi bi-check-circle text-success" style="font-size: 2rem;"></i>
                        <p class="text-muted mt-2 mb-0">All clear! No recent handover incidents.</p>
                    </div>
                {% endif %}
            </div>
        </div>

        <div class="col-lg-6">
            <div class="modern-content-card">
                <h5 class="d-flex align-items-center mb-3">
                    <i class="bi bi-people-fill text-info me-2"></i>
                    Shift Status
                </h5>
                <div class="row">
                    <div class="col-6">
                        <h6 class="shift-header">Current ({{ current_shift_type }})</h6>
                        {% if current_engineers %}
                            {% for engineer in current_engineers %}
                            <div class="engineer-item">
                                <span class="shift-status-indicator shift-active"></span>
                                <span class="engineer-name">{{ engineer|safe_engineer_name }}</span>
                            </div>
                            {% endfor %}
                        {% else %}
                        <div class="no-engineers">
                            <i class="bi bi-person-x text-muted"></i>
                            <span class="text-muted">No engineers assigned</span>
                        </div>
                        {% endif %}
                    </div>
                    <div class="col-6">
                        <h6 class="shift-header">Next ({{ next_shift_type }})</h6>
                        {% if next_shift_engineers %}
                            {% for engineer in next_shift_engineers %}
                            <div class="engineer-item">
                                <span class="shift-status-indicator shift-upcoming"></span>
                                <span class="engineer-name">{{ engineer|safe_engineer_name }}</span>
                            </div>
                            {% endfor %}
                        {% else %}
                        <div class="no-engineers">
                            <i class="bi bi-person-x text-muted"></i>
                            <span class="text-muted">No engineers assigned</span>
                        </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Action Items Card -->
    <div class="row g-3 mt-3">
        <div class="col-12">
            <div class="metric-card">
                <h5 class="d-flex align-items-center mb-3">
                    <i class="bi bi-exclamation-triangle text-danger me-2"></i>
                    Priority Incidents (High & Critical)
                    {% if priority_incidents|length > 0 %}
                    <span class="badge bg-danger text-white ms-2">{{ priority_incidents|length }}</span>
                    {% endif %}
                </h5>
                {% if priority_incidents %}
                <div class="list-group">
                    {% for incident in priority_incidents %}
                    <div class="list-group-item d-flex justify-content-between align-items-center">
                        <div>
                            <strong>{{ incident.title }}</strong>
                            <br>
                            <small class="text-muted">{{ incident.description if incident.description else 'No description available' }}</small>
                        </div>
                        <div class="text-end">
                            <span class="badge bg-{{ 'danger' if incident.priority == 'Critical' else 'warning' }} me-1">
                                {{ incident.priority }}
                            </span>
                            <span class="badge bg-{{ 'danger' if incident.type == 'Priority' else 'info' }}">
                                {{ incident.type }}
                            </span>
                        </div>
                    </div>
                    {% endfor %}
                </div>
                {% else %}
                <div class="text-center py-4">
                    <i class="bi bi-check-circle text-success" style="font-size: 2rem;"></i>
                    <p class="text-muted mt-2 mb-0">No priority incidents at the moment!</p>
                </div>
                {% endif %}
            </div>
        </div>
    </div>

    <!-- Open Key Points (Pending Actions) Section -->
    <div class="row g-3 mt-3">
        <div class="col-12">
            <div class="metric-card">
                <h5 class="d-flex align-items-center mb-3">
                    <i class="bi bi-list-check text-warning me-2"></i>
                    Pending Action Items (Open & In Progress)
                    {% if open_key_points|length > 0 %}
                    <span class="badge bg-warning text-dark ms-2">{{ open_key_points|length }}</span>
                    {% endif %}
                </h5>
                {% if open_key_points %}
                <div class="list-group">
                    {% for kp in open_key_points %}
                    <div class="list-group-item d-flex justify-content-between align-items-center">
                        <span>{{ kp.description }}</span>
                        <span class="badge bg-{{ 'warning' if kp.status == 'Open' else 'info' if kp.status == 'In Progress' else 'success' }}">
                            {{ kp.status }}
                        </span>
                    </div>
                    {% endfor %}
                </div>
                {% else %}
                <div class="text-center py-4">
                    <i class="bi bi-check-all text-success" style="font-size: 2rem;"></i>
                    <p class="text-muted mt-2 mb-0">All action items completed!</p>
                </div>
                {% endif %}
            </div>
        </div>
    </div>

    <!-- Enhanced Analytics Section -->
    <div class="mt-4">
        <div class="chart-container">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4>📊 Analytics Overview</h4>
                <form method="get" class="row g-2 align-items-end">
                    <div class="col-auto">
                        <label for="range" class="form-label">Time Period</label>
                        <select name="range" id="range" class="form-control">
                            <option value="1d" {% if selected_range == '1d' %}selected{% endif %}>Last 24 Hours</option>
                            <option value="7d" {% if selected_range == '7d' or not selected_range %}selected{% endif %}>Last 7 Days</option>
                            <option value="30d" {% if selected_range == '30d' %}selected{% endif %}>Last 30 Days</option>
                            <option value="1y" {% if selected_range == '1y' %}selected{% endif %}>Last Year</option>
                            <option value="custom" {% if selected_range == 'custom' %}selected{% endif %}>Custom Range</option>
                        </select>
                    </div>
                    <div class="col-auto" id="custom-date-fields" {% if selected_range != 'custom' %}style="display:none;"{% endif %}>
                        <div class="row g-2">
                            <div class="col">
                                <label for="start_date" class="form-label">From</label>
                                <input type="date" name="start_date" id="start_date" class="form-control" value="{{ start_date }}">
                            </div>
                            <div class="col">
                                <label for="end_date" class="form-label">To</label>
                                <input type="date" name="end_date" id="end_date" class="form-control" value="{{ end_date }}">
                            </div>
                        </div>
                    </div>
                    <div class="col-auto">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-arrow-clockwise me-1"></i>Apply
                        </button>
                    </div>
                </form>
            </div>
            
            <!-- Charts Row -->
            <div class="row g-4">
                <div class="col-12">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">Incident Trends</h5>
                            <div id="main-chart" style="height: 400px; width: 100%;"></div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Secondary Charts Row -->
            <div class="row g-4 mt-2">
                <div class="col-lg-6">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">Priority Distribution</h5>
                            <div id="incident-pie-chart" style="height: 300px;"></div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">Summary Stats</h5>
                            <div class="row text-center">
                                <div class="col-4">
                                    <h3 class="text-primary">{{ open_incidents|length }}</h3>
                                    <small class="text-muted">Open</small>
                                </div>
                                <div class="col-4">
                                    <h3 class="text-success">{{ priority_incidents|length }}</h3>
                                    <small class="text-muted">Priority</small>
                                </div>
                                <div class="col-4">
                                    <h3 class="text-warning">{{ open_key_points|length }}</h3>
                                    <small class="text-muted">Actions</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- JavaScript for Enhanced Functionality -->
    <script>
        // Real-time clock update with consistent formatting
        function updateTime() {
            const now = new Date();
            
            // Define consistent day and month names to avoid fluctuation
            const dayNames = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
            const monthNames = ['January', 'February', 'March', 'April', 'May', 'June', 
                              'July', 'August', 'September', 'October', 'November', 'December'];
            
            // Convert to IST (Asia/Kolkata timezone)
            const istTime = new Date(now.toLocaleString("en-US", {timeZone: "Asia/Kolkata"}));
            
            // Extract date components
            const dayName = dayNames[istTime.getDay()];
            const day = istTime.getDate();
            const monthName = monthNames[istTime.getMonth()];
            const year = istTime.getFullYear();
            
            // Format time components with leading zeros
            const hours = istTime.getHours().toString().padStart(2, '0');
            const minutes = istTime.getMinutes().toString().padStart(2, '0');
            const seconds = istTime.getSeconds().toString().padStart(2, '0');
            
            // Create consistent format: "Sunday, 26 October, 2025, 11:47:41 pm"
            const period = istTime.getHours() >= 12 ? 'pm' : 'am';
            const displayHours = istTime.getHours() % 12 || 12;
            
            const formattedTime = `${dayName}, ${day} ${monthName}, ${year}, ${displayHours}:${minutes}:${seconds} ${period}`;
            
            document.getElementById('current-time').textContent = formattedTime;
        }
        setInterval(updateTime, 1000);
        updateTime();

        // Custom date range toggle
        document.getElementById('range').addEventListener('change', function() {
            var customFields = document.getElementById('custom-date-fields');
            if (this.value === 'custom') {
                customFields.style.display = '';
            } else {
                customFields.style.display = 'none';
            }
        });

        // Enhanced Plotly Charts
        try {
            // Use the graphJSON data passed from the backend
            const graphData = {{ graphJSON|safe }};
            if (graphData && graphData.data && graphData.layout) {
                // Enhance layout for better display
                graphData.layout.height = 400;
                graphData.layout.margin = {t: 50, r: 50, b: 50, l: 50};
                graphData.layout.showlegend = true;
                graphData.layout.legend = {x: 0, y: 1};
                
                Plotly.newPlot('main-chart', graphData.data, graphData.layout, {responsive: true, displayModeBar: false});
            } else {
                throw new Error('No graph data available');
            }
        } catch (error) {
            console.log('Using default chart data:', error);
            // Default chart if no data
            const defaultData = [{
                x: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
                y: [2, 1, 3, 0, 4, 1, 2],
                type: 'scatter',
                mode: 'lines+markers',
                name: 'Sample Incidents',
                line: {color: '#ff6b6b'},
                marker: {color: '#ff6b6b', size: 8}
            }];
            const defaultLayout = {
                title: 'Incident Trends (Sample Data)',
                xaxis: {title: 'Day'},
                yaxis: {title: 'Count'},
                height: 400,
                margin: {t: 50, r: 50, b: 50, l: 50},
                showlegend: true
            };
            Plotly.newPlot('main-chart', defaultData, defaultLayout, {responsive: true, displayModeBar: false});
        }

        // Incident Priority Pie Chart
        try {
            const priorityData = {{ priority_distribution|safe }};
            const incidentData = [{
                values: [
                    priorityData.critical || 0,
                    priorityData.high || 0,
                    priorityData.medium || 0,
                    priorityData.low || 0
                ],
                labels: ['Critical', 'High', 'Medium', 'Low'],
                type: 'pie',
                marker: {
                    colors: ['#e74c3c', '#f39c12', '#f1c40f', '#2ecc71']
                },
                textinfo: 'label+percent',
                textposition: 'outside'
            }];
            
            const incidentLayout = {
                title: 'Priority Distribution',
                margin: {t: 40, r: 40, b: 40, l: 40},
                showlegend: true,
                legend: {
                    orientation: 'h',
                    x: 0.5,
                    xanchor: 'center',
                    y: -0.1
                },
                height: 300
            };
            
            Plotly.newPlot('incident-pie-chart', incidentData, incidentLayout, {responsive: true, displayModeBar: false});
        } catch (error) {
            console.log('Error creating pie chart:', error);
            // Simple fallback pie chart
            const fallbackData = [{
                values: [{{ priority_incidents|length }}, {{ open_incidents|length - priority_incidents|length }}],
                labels: ['Priority', 'Regular'],
                type: 'pie',
                marker: {
                    colors: ['#e74c3c', '#3498db']
                }
            }];
            const fallbackLayout = {
                title: 'Incident Distribution',
                margin: {t: 40, r: 40, b: 40, l: 40},
                height: 300
            };
            Plotly.newPlot('incident-pie-chart', fallbackData, fallbackLayout, {responsive: true, displayModeBar: false});
        }

        // Auto-refresh functionality
        setTimeout(function() {
            location.reload();
        }, 300000); // Refresh every 5 minutes

        // Modern Dashboard Enhancements
        document.addEventListener('DOMContentLoaded', function() {
            // Animated Counter Effect
            function animateCounter(element) {
                const target = parseInt(element.getAttribute('data-target'));
                const increment = Math.ceil(target / 30);
                let current = 0;
                
                const timer = setInterval(() => {
                    current += increment;
                    if (current >= target) {
                        current = target;
                        clearInterval(timer);
                    }
                    element.textContent = current;
                }, 50);
            }

            // Trigger counter animations
            document.querySelectorAll('.counter').forEach(counter => {
                animateCounter(counter);
            });

            // Time update is handled by the main function above
            // Removed duplicate updateTime function to prevent conflicts

            // Card Hover Effects with 3D Transform
            document.querySelectorAll('.modern-stats-card').forEach(card => {
                card.addEventListener('mouseenter', function() {
                    this.style.transform = 'translateY(-8px) scale(1.02) rotateX(5deg)';
                });
                
                card.addEventListener('mouseleave', function() {
                    this.style.transform = 'translateY(0) scale(1) rotateX(0)';
                });
            });

            // Stagger Animation for Cards
            document.querySelectorAll('.modern-stats-card').forEach((card, index) => {
                card.style.animationDelay = `${index * 0.1}s`;
                card.classList.add('fadeInUp');
            });

            // Smooth Scroll for Page Elements
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.style.opacity = '1';
                        entry.target.style.transform = 'translateY(0)';
                    }
                });
            });

            document.querySelectorAll('.modern-content-card').forEach(card => {
                card.style.opacity = '0';
                card.style.transform = 'translateY(20px)';
                card.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
                observer.observe(card);
            });

            // Loading State for Stats
            document.querySelectorAll('.stats-number').forEach(element => {
                element.classList.add('loading');
                setTimeout(() => {
                    element.classList.remove('loading');
                }, 1000);
            });

            // Load incident assignment notifications for dashboard
            loadDashboardNotifications();
        });

        // Dashboard Notifications Functions
        function loadDashboardNotifications() {
            console.log('🔔 Loading dashboard notifications...');
            fetch('/api/get_pending_assignments')
                .then(response => {
                    console.log('📡 API Response status:', response.status);
                    return response.json();
                })
                .then(data => {
                    console.log('📊 API Response data:', data);
                    if (data.success && data.assignments && data.assignments.length > 0) {
                        console.log(`✅ Found ${data.assignments.length} pending assignments for dashboard`);
                        displayDashboardNotifications(data.assignments);
                    } else {
                        console.log('ℹ️ No pending assignments found or API returned no data');
                        console.log('Data structure:', {
                            success: data.success,
                            assignments: data.assignments ? data.assignments.length : 'undefined',
                            raw: data
                        });
                    }
                })
                .catch(error => {
                    console.error('❌ Error loading dashboard notifications:', error);
                });
        }

        function displayDashboardNotifications(assignments) {
            console.log('🎯 Displaying dashboard notifications:', assignments);
            const panel = document.getElementById('incident-notifications-dashboard');
            const countSpan = document.getElementById('notifications-count');
            const summaryDiv = document.getElementById('notifications-summary');
            const listDiv = document.getElementById('notifications-list-dashboard');

            // Update count
            countSpan.textContent = assignments.length;

            // Create summary
            const priorities = assignments.map(a => a.incident_priority);
            const highCount = priorities.filter(p => p === 'High' || p === 'Critical').length;
            const mediumCount = priorities.filter(p => p === 'Medium').length;
            const lowCount = priorities.filter(p => p === 'Low').length;

            let summaryText = [];
            if (highCount > 0) summaryText.push(`${highCount} High priority`);
            if (mediumCount > 0) summaryText.push(`${mediumCount} Medium priority`);
            if (lowCount > 0) summaryText.push(`${lowCount} Low priority`);

            summaryDiv.innerHTML = `<strong>Priority breakdown:</strong> ${summaryText.join(', ')}`;

            // Create detailed list
            listDiv.innerHTML = assignments.map(assignment => `
                <div class="card mb-2">
                    <div class="card-body p-3">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="flex-grow-1">
                                <h6 class="card-title mb-1">
                                    <i class="fas fa-exclamation-triangle text-${getPriorityColor(assignment.incident_priority)} me-2"></i>
                                    ${assignment.incident_title}
                                    <span class="badge bg-${getPriorityColor(assignment.incident_priority)} ms-2">${assignment.incident_priority}</span>
                                </h6>
                                <p class="card-text text-muted mb-2">${assignment.incident_description || 'No description provided'}</p>
                                <small class="text-muted">
                                    <i class="fas fa-user me-1"></i>Assigned by: ${assignment.assigned_by}
                                    <span class="ms-3"><i class="fas fa-clock me-1"></i>${assignment.created_at}</span>
                                </small>
                            </div>
                            <div class="ms-3">
                                <button class="btn btn-success btn-sm me-1" onclick="respondToAssignment(${assignment.id}, 'accepted')">
                                    <i class="fas fa-check me-1"></i>Accept
                                </button>
                                <button class="btn btn-danger btn-sm" onclick="respondToAssignment(${assignment.id}, 'rejected')">
                                    <i class="fas fa-times me-1"></i>Reject
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            `).join('');

            // Show the panel
            console.log('👁️ Showing notification panel');
            panel.style.display = 'block';
            console.log('✅ Dashboard notifications displayed successfully');
        }

        function getPriorityColor(priority) {
            switch(priority?.toLowerCase()) {
                case 'critical':
                case 'high': return 'danger';
                case 'medium': return 'warning';
                case 'low': return 'info';
                default: return 'secondary';
            }
        }

        function toggleNotificationsList() {
            const listDiv = document.getElementById('notifications-list-dashboard');
            const icon = document.getElementById('toggle-notifications-icon');
            
            if (listDiv.style.display === 'none') {
                listDiv.style.display = 'block';
                icon.className = 'fas fa-chevron-up';
            } else {
                listDiv.style.display = 'none';
                icon.className = 'fas fa-chevron-down';
            }
        }

        function viewAllNotifications() {
            window.location.href = '/notifications';
        }

        function respondToAssignment(assignmentId, response) {
            const comments = prompt(`Please provide comments for your ${response} response:`);
            if (comments === null) return; // User cancelled

            fetch('/api/respond_to_assignment', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    assignment_id: assignmentId,
                    status: response,  // Fixed: send as 'status' not 'response'
                    comments: comments
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert(`Assignment ${response} successfully!`);
                    // Reload notifications to update the display
                    loadDashboardNotifications();
                    // Reload page to refresh all data
                    setTimeout(() => location.reload(), 1000);
                } else {
                    alert('Error: ' + (data.error || 'Unknown error occurred'));
                }
            })
            .catch(error => {
                console.error('Error responding to assignment:', error);
                alert('Error submitting response. Please try again.');
            });
        }

        // Load notifications when page loads
        window.addEventListener('DOMContentLoaded', function() {
            loadDashboardNotifications();
        });
    </script>

    <style>
        /* Additional CSS for enhanced animations */
        .fadeInUp {
            animation: fadeInUp 0.8s ease-out forwards;
        }
        
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        /* Enhanced 3D effects */
        .modern-stats-card {
            perspective: 1000px;
            transform-style: preserve-3d;
        }
        
        /* Smooth transitions for all elements */
        * {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
    </style>
</div>
{% endblock %}

